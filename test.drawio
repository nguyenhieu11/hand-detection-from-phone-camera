<mxfile host="app.diagrams.net" modified="2026-05-14T10:00:00.000Z" agent="GitHub Copilot" version="24.7.17" type="device">
	<diagram id="slide1" name="1_Problems">
		<mxGraphModel dx="1280" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1366" pageHeight="768" math="0" shadow="0">
			<root>
				<mxCell id="0"/>
				<mxCell id="1" parent="0"/>
				<mxCell id="title1" value="Slide 1 — Problem Need to Be Solved" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=36;fontStyle=1;fontColor=#1A237E;" vertex="1" parent="1">
					<mxGeometry x="40" y="24" width="1000" height="60" as="geometry"/>
				</mxCell>
				<mxCell id="box1" value="Goal: Run an AI model to detect hands from phone camera video in near real-time." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#5C6BC0;fontSize=20;fontStyle=1;align=left;spacing=16;" vertex="1" parent="1">
					<mxGeometry x="40" y="100" width="1280" height="90" as="geometry"/>
				</mxCell>
				<mxCell id="p11" value="Context from repo: hand-detection-from-phone-camera" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#263238;" vertex="1" parent="1">
					<mxGeometry x="40" y="220" width="900" height="40" as="geometry"/>
				</mxCell>
				<mxCell id="p12" value="• Input source is not local only: must accept phone camera stream (RTSP).&#xa;• AI model inference must run on laptop CPU (ONNX Runtime + OpenCV C++).&#xa;• Need low latency: avoid stale frames while streaming over Wi-Fi.&#xa;• Need easy visualization for user: browser-based output stream." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#90A4AE;fontSize=20;align=left;verticalAlign=top;spacing=14;" vertex="1" parent="1">
					<mxGeometry x="40" y="270" width="1280" height="280" as="geometry"/>
				</mxCell>
				<mxCell id="p13" value="Success criteria" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#263238;" vertex="1" parent="1">
					<mxGeometry x="40" y="580" width="500" height="40" as="geometry"/>
				</mxCell>
				<mxCell id="p14" value="Detect hand with stable confidence, show bounding boxes, and serve processed stream at http://&lt;laptop-ip&gt;:8080." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#66BB6A;fontSize=18;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1">
					<mxGeometry x="40" y="620" width="1280" height="100" as="geometry"/>
				</mxCell>
			</root>
		</mxGraphModel>
	</diagram>

	<diagram id="slide2" name="2_Solutions">
		<mxGraphModel dx="1280" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1366" pageHeight="768" math="0" shadow="0">
			<root>
				<mxCell id="0"/>
				<mxCell id="1" parent="0"/>
				<mxCell id="title2" value="Slide 2 — Solution" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=36;fontStyle=1;fontColor=#1A237E;" vertex="1" parent="1">
					<mxGeometry x="40" y="24" width="700" height="60" as="geometry"/>
				</mxCell>
				<mxCell id="s21" value="Implementation from provided repos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#42A5F5;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
					<mxGeometry x="40" y="100" width="1280" height="70" as="geometry"/>
				</mxCell>
				<mxCell id="s22" value="• App: C++ pipeline in main.cpp (OpenCV + ONNX Runtime).&#xa;• Model: best.onnx (YOLOv8 hand detector).&#xa;• Stream ingest: RTSP from phone (Larix app).&#xa;• RTSP relay/server: MediaMTX (port 8554).&#xa;• Output serving: built-in MJPEG HTTP server (default port 8080).&#xa;• Client viewing: browser on phone/laptop to monitor annotated stream." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#90A4AE;fontSize=20;align=left;verticalAlign=top;spacing=14;" vertex="1" parent="1">
					<mxGeometry x="40" y="190" width="860" height="420" as="geometry"/>
				</mxCell>
				<mxCell id="s23" value="Key technical choices" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FFB300;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
					<mxGeometry x="930" y="190" width="390" height="70" as="geometry"/>
				</mxCell>
				<mxCell id="s24" value="• Letterbox to 320×320&#xa;• CPU-optimized ONNX Runtime&#xa;• Confidence threshold: 0.6&#xa;• NMS threshold: 0.45&#xa;• Grab thread to reduce RTSP latency" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDF7;strokeColor=#FFCC80;fontSize=18;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1">
					<mxGeometry x="930" y="280" width="390" height="330" as="geometry"/>
				</mxCell>
				<mxCell id="s25" value="Result: End-to-end working hand detection from phone camera to web visualization." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#66BB6A;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
					<mxGeometry x="40" y="640" width="1280" height="80" as="geometry"/>
				</mxCell>
			</root>
		</mxGraphModel>
	</diagram>

