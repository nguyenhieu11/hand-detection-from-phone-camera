	<diagram id="slide4" name="4_Model_Training">
		<mxGraphModel dx="1280" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1366" pageHeight="768" math="0" shadow="0">
			<root>
				<mxCell id="0"/>
				<mxCell id="1" parent="0"/>
				<mxCell id="title4" value="Slide 4 — How the AI Model Was Trained" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=36;fontStyle=1;fontColor=#1A237E;" vertex="1" parent="1">
					<mxGeometry x="40" y="24" width="1000" height="60" as="geometry"/>
				</mxCell>
				<mxCell id="t41" value="Approach: Fine-tune pretrained YOLOv8n with Google Colab (free T4 GPU)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#5C6BC0;fontSize=20;fontStyle=1;align=left;spacing=14;" vertex="1" parent="1">
					<mxGeometry x="40" y="100" width="1280" height="80" as="geometry"/>
				</mxCell>

				<mxCell id="t42" value="Training pipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#42A5F5;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
					<mxGeometry x="40" y="210" width="1280" height="60" as="geometry"/>
				</mxCell>
				<mxCell id="t43" value="1 Install ultralytics + roboflow + onnx in Colab&#xa;2 Mount Google Drive for persistent storage&#xa;3 Download EgoHands dataset from Roboflow (YOLOv8 format)&#xa;4 Fine-tune yolov8n.pt (epochs=50, imgsz=320, batch=16)&#xa;5 Validate metrics (target mAP50 &gt; 0.80)&#xa;6 Export best.pt → best.onnx (opset 12)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#90A4AE;fontSize=19;align=left;verticalAlign=top;spacing=14;" vertex="1" parent="1">
					<mxGeometry x="40" y="290" width="860" height="360" as="geometry"/>
				</mxCell>

				<mxCell id="t44" value="Why this method?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FFB300;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
					<mxGeometry x="930" y="290" width="390" height="70" as="geometry"/>
				</mxCell>
				<mxCell id="t45" value="• Fast to train with transfer learning&#xa;• Good accuracy for single class (hand)&#xa;• ONNX export works well in C++ runtime&#xa;• Lightweight enough for edge deployment later" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDF7;strokeColor=#FFCC80;fontSize=18;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1">
					<mxGeometry x="930" y="380" width="390" height="270" as="geometry"/>
				</mxCell>

				<mxCell id="t46" value="Output artifact used in deployment repo: best.onnx" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#66BB6A;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
					<mxGeometry x="40" y="670" width="1280" height="55" as="geometry"/>
				</mxCell>
			</root>
		</mxGraphModel>
	</diagram>
